{
  "name": "ai-power-guild",
  "description": "Agent skills that connect an AI environment to the AI Power Guild app (pg.singleton.ai) and run member onboarding, profile, and intake flows.",
  "version": "0.3.1",
  "author": {
    "name": "Andy Singleton",
    "email": "andy@singleton.ai"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/skills/guild-connect/scripts/memory-hook.mjs\" recall",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/skills/guild-connect/scripts/memory-hook.mjs\" retain",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
